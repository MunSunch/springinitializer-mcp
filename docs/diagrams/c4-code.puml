@startuml c4-code
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title Диаграмма кода — Spring Initializr MCP Server

System_Ext(mcp_client, "MCP-клиент", "AI-ассистент")
System_Ext(spring_api, "Spring Initializr API", "start.spring.io")

Container_Boundary(server, "MCP Server") {
    Component(index, "index.ts", "Точка входа", "Разбирает аргументы CLI, создаёт McpServer, запускает stdio или HTTP транспорт")
    Component(generate_project, "generate-project.ts", "MCP Tool", "Динамически строит схему инструмента из метаданных и выполняет валидацию")
    Component(url_builder, "url-builder.ts", "URL Utility", "Построение URL для Spring Initializr с кодированием параметров")
    Component(metadata_mod, "metadata.ts", "Метаданные", "Загрузка и кэширование метаданных Spring Initializr, общие типы")
    Component(metadata, "spring-initializr-metadata.ts", "MCP Resources", "Предоставляет опции, зависимости, зависимости по категориям из API")
    Component(prompt, "generate-project-prompt.ts", "MCP Prompt", "Структурированный промпт для пошаговой генерации проекта")
    Component(download, "download.ts", "Загрузка", "HTTP-загрузка ZIP-архива в память")
    Component(logger, "logger.ts", "Логгер", "Уровневое логирование: stderr для stdio / stdout для HTTP")
}

Rel(mcp_client, index, "MCP Protocol")
Rel(index, generate_project, "registerTools()")
Rel(index, metadata, "registerResources()")
Rel(index, prompt, "registerPrompts()")
Rel(generate_project, url_builder, "buildDownloadUrl()")
Rel(generate_project, metadata_mod, "Строит схему и валидирует параметры")
Rel(generate_project, download, "fetchZip()")
Rel(metadata, metadata_mod, "fetchMetadata()")
Rel(generate_project, logger, "Логирует операции")
Rel(metadata, spring_api, "Запрашивает метаданные", "HTTPS")
Rel(download, spring_api, "Скачивает ZIP", "HTTPS")

@enduml